{
  "name": "resumebuddy",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "next dev --port 9002",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:auth": "vitest run tests/auth/",
    "test:api": "vitest run tests/api/",
    "test:business": "vitest run tests/business/",
    "test:storage": "vitest run tests/storage/",
    "test:e2e": "vitest run tests/e2e/",
    "test:perf": "vitest run tests/performance/",
    "test:all-phases": "powershell -ExecutionPolicy Bypass -File scripts/test-all-phases-v2.ps1",
    "latex:smoke": "node scripts/latex-smoke-test.mjs",
    "lighthouse": "lighthouse http://localhost:3000 --view --preset=desktop",
    "perf:audit": "npm run build && npm run lighthouse",
    "tokens:estimate": "npx ts-node scripts/token-estimator.ts",
    "db:stats": "curl http://localhost:3000/api/admin/cleanup",
    "db:cleanup": "curl -X POST http://localhost:3000/api/admin/cleanup -H 'Content-Type: application/json' -d '{\"action\":\"cleanup\",\"retentionDays\":7}'",
    "db:emergency-cleanup": "curl -X POST http://localhost:3000/api/admin/cleanup -H 'Content-Type: application/json' -d '{\"action\":\"emergency\",\"retentionDays\":3}'",
    "infra:up": "cd infrastructure/docker && docker compose up -d postgres redis minio",
    "infra:down": "cd infrastructure/docker && docker compose down",
    "infra:ps": "cd infrastructure/docker && docker compose ps",
    "infra:logs": "cd infrastructure/docker && docker compose logs -f",
    "infra:setup": "powershell -ExecutionPolicy Bypass -File infrastructure/scripts/setup.ps1",
    "infra:reset": "cd infrastructure/docker && docker compose down -v && docker compose up -d postgres redis minio",
    "db:generate": "cd packages/database && npx prisma generate",
    "db:migrate": "cd packages/database && npx prisma migrate dev",
    "db:studio": "cd packages/database && npx prisma studio"
  },
  "dependencies": {
    "@genkit-ai/googleai": "1.19.3",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "3.9.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^6.9.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@supabase/supabase-js": "^2.58.0",
    "@types/cheerio": "^0.22.35",
    "@types/lodash": "^4.17.20",
    "@types/react-image-crop": "^8.1.6",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.3.1",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
