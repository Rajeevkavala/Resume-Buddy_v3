    "@types/bcryptjs": "^2.4.6",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-dropzone": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.9.11",
    "canvas": "^3.2.1",
    "cssnano": "^7.1.1",
    "genkit-cli": "1.19.3",
