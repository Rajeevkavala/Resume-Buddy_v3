# =============================================================
# ResumeBuddy — Production Environment Variables
# =============================================================
# Copy to .env.local (NEVER commit .env.local to git)
# All values marked [REQUIRED] must be set before deployment.
# =============================================================

# ─────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app        # [REQUIRED]
SESSION_COOKIE_NAME=rb_session

# ─────────────────────────────────────────────────────────────
# DATABASE — Supabase PostgreSQL
# ─────────────────────────────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → Database → Connection string (URI)
# Use the "Transaction" pooler (port 6543) for serverless / Vercel
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true   # [REQUIRED]
# Direct connection (used by Prisma migrations only — NOT runtime)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres                   # [REQUIRED for migrations]

# ─────────────────────────────────────────────────────────────
# REDIS — Upstash
# ─────────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → Database → REST API section
# Use the TLS (rediss://) URL for production
REDIS_URL=rediss://:[password]@[endpoint].upstash.io:6380    # [REQUIRED]
REDIS_PASSWORD=your-upstash-password                          # [REQUIRED]

# ─────────────────────────────────────────────────────────────
# OBJECT STORAGE — MinIO on DigitalOcean Droplet
# ─────────────────────────────────────────────────────────────
# Your DigitalOcean Droplet's public IP or domain
MINIO_ENDPOINT=your-droplet-ip-or-domain    # [REQUIRED]  e.g. 165.232.181.37
MINIO_PORT=9000
MINIO_ACCESS_KEY=your-minio-access-key      # [REQUIRED]
MINIO_SECRET_KEY=your-minio-secret-key      # [REQUIRED]
MINIO_USE_SSL=false                          # Set to true if behind HTTPS proxy
MINIO_BUCKET=resumebuddy

# ─────────────────────────────────────────────────────────────
# SERVICES
# ─────────────────────────────────────────────────────────────
# LaTeX compilation service on DigitalOcean
LATEX_SERVICE_URL=http://your-droplet-ip:8080    # [REQUIRED]

# WebSocket service on Vercel (separate project)
WEBSOCKET_URL=https://resumebuddy-websocket.vercel.app   # [REQUIRED]

# ─────────────────────────────────────────────────────────────
# AUTH SECRETS (generate with: openssl rand -base64 48)
# ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48   # [REQUIRED] min 32 chars
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48  # [REQUIRED] min 32 chars
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48      # [REQUIRED] min 32 chars

# ─────────────────────────────────────────────────────────────
# AI PROVIDERS — Fallback chain: Groq → Gemini → OpenRouter
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxx            # [REQUIRED] primary (llama-3.1-8b / llama-3.3-70b)
GOOGLE_API_KEY=AIzaxxxxx          # [REQUIRED] backup (gemini-1.5-flash)
OPENROUTER_API_KEY=sk-or-xxxxx    # [RECOMMENDED] last resort fallback

# ─────────────────────────────────────────────────────────────
# PAYMENTS — Razorpay
# ─────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxx           # [REQUIRED for billing]
RAZORPAY_KEY_SECRET=your-secret          # [REQUIRED for billing]
RAZORPAY_WEBHOOK_SECRET=your-wh-secret   # [REQUIRED for billing]

# ─────────────────────────────────────────────────────────────
# OAUTH — Google
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com   # [REQUIRED for OAuth]
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx                   # [REQUIRED for OAuth]
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/google/callback

# ─────────────────────────────────────────────────────────────
# EMAIL — Resend
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxx      # [REQUIRED for OTP / password reset]
FROM_EMAIL=noreply@yourdomain.com

# ─────────────────────────────────────────────────────────────
# SMS / WHATSAPP (optional) — Twilio
# ─────────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxx
# TWILIO_AUTH_TOKEN=xxxxx
# TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890
