{
  "name": "resume-latex-service",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "docker:build": "docker build -t resume-latex-service .",
    "docker:run": "docker run --rm -p 8080:8080 -m 1536m resume-latex-service",
    "docker:run:bg": "docker run -d --name latex-service -p 8080:8080 -m 1536m --restart unless-stopped resume-latex-service",
    "health": "curl -s http://localhost:8080/healthz",
    "metrics": "curl -s http://localhost:8080/metrics | jq",
    "test:load": "node --experimental-fetch -e \"Promise.all(Array(10).fill().map((_,i) => fetch('http://localhost:8080/v1/resume/latex/compile', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({source:'resumeText',templateId:'professional',resumeText:'Test User '+i+'\\n\\nSoftware Engineer',options:{engine:'tectonic',return:['pdf']}})}).then(r=>r.json()).then(d=>console.log('Request',i,d.ok?'OK':'FAIL',d.cached?'(cached)':''))));\""
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
