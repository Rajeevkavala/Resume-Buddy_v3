# Ignore services (should be deployed separately - root-level only)
/services/

# Ignore non-essential directories (root-level only)
/apps/websocket/
/docs/
/scripts/
/tests/
/infrastructure/
/prompts/
/patches/
/pencil_designs/

# Remove committed node_modules from workspace packages
# (npm install handles all deps via root package.json)
packages/*/node_modules/
apps/*/node_modules/

# Ignore config files
.env.local
.env.development
*.local

# Ignore build artifacts (root-level only)
/dist/
/coverage/
*.log
