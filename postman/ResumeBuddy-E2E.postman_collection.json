          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"{{password}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}" },
            "url": { "raw": "{{apiBase}}/auth/password/change", "host": ["{{apiBase}}"], "path": ["auth", "password", "change"] }
          }
        },
        {
          "name": "Password Reset Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\"\n}" },
            "url": { "raw": "{{apiBase}}/auth/password/reset", "host": ["{{apiBase}}"], "path": ["auth", "password", "reset"] }
          }
        },
        {
          "name": "Password Reset Confirm",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"code\": \"{{resetCode}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}" },
            "url": { "raw": "{{apiBase}}/auth/password/reset/confirm", "host": ["{{apiBase}}"], "path": ["auth", "password", "reset", "confirm"] }
          }
