            "url": { "raw": "{{apiBase}}/auth/profile/photo", "host": ["{{apiBase}}"], "path": ["auth", "profile", "photo"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Photo upload returns 200/400/401', function () { pm.expect([200,400,401]).to.include(pm.response.code); });"] } }]
