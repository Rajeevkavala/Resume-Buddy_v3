{
  "info": {
    "name": "ResumeBuddy E2E API",
    "_postman_id": "d8dd7034-f8b9-4385-bc4a-74717f2f67d0",
    "description": "End-to-end Postman collection covering all Next.js API routes for ResumeBuddy.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.environment.set('requestId', `${Date.now()}-${Math.floor(Math.random()*100000)}`);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response time is under 10s', function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(10000);",
          "});"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "{{baseUrl}}" },
    { "key": "apiBase", "value": "{{apiBase}}" }
  ],
  "item": [
    {
      "name": "00 Health & Metrics",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{apiBase}}/health", "host": ["{{apiBase}}"], "path": ["health"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Health returns 200 or 503', function () { pm.expect([200,503]).to.include(pm.response.code); });"] } }]
        },
        {
          "name": "Metrics",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminApiKey}}", "disabled": true }
            ],
            "url": { "raw": "{{apiBase}}/metrics", "host": ["{{apiBase}}"], "path": ["metrics"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Metrics returns 200/401', function () { pm.expect([200,401]).to.include(pm.response.code); });"] } }]
        }
      ]
    },
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"name\": \"{{name}}\"\n}"
            },
            "url": { "raw": "{{apiBase}}/auth/register", "host": ["{{apiBase}}"], "path": ["auth", "register"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Register returns 201 or already exists', function () { pm.expect([201,409,400]).to.include(pm.response.code); });", "if (pm.response.code === 201) { const j = pm.response.json(); if (j.accessToken) pm.environment.set('accessToken', j.accessToken); if (j.user && j.user.id) pm.environment.set('userId', j.user.id); }"] } }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": { "raw": "{{apiBase}}/auth/login", "host": ["{{apiBase}}"], "path": ["auth", "login"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Login returns success', function () { pm.response.to.have.status(200); });", "const j = pm.response.json(); if (j.accessToken) pm.environment.set('accessToken', j.accessToken); if (j.user && j.user.id) pm.environment.set('userId', j.user.id);"] } }]
        },
        {
          "name": "Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{apiBase}}/auth/session", "host": ["{{apiBase}}"], "path": ["auth", "session"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Session returns 200 or 401', function () { pm.expect([200,401]).to.include(pm.response.code); });", "if (pm.response.code === 200) { const j = pm.response.json(); if (j.accessToken) pm.environment.set('accessToken', j.accessToken); if (j.user && j.user.id) pm.environment.set('userId', j.user.id); }"] } }]
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{apiBase}}/auth/refresh", "host": ["{{apiBase}}"], "path": ["auth", "refresh"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Refresh returns 200 or 401', function () { pm.expect([200,401]).to.include(pm.response.code); });", "if (pm.response.code === 200) { const j = pm.response.json(); if (j.accessToken) pm.environment.set('accessToken', j.accessToken); }"] } }]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{apiBase}}/auth/logout", "host": ["{{apiBase}}"], "path": ["auth", "logout"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Logout returns 200', function () { pm.response.to.have.status(200); });"] } }]
        },
        {
          "name": "Google OAuth URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/auth/google?returnTo=%2Fdashboard",
              "host": ["{{apiBase}}"],
              "path": ["auth", "google"],
              "query": [{ "key": "returnTo", "value": "/dashboard" }]
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Google auth URL returns 200', function () { pm.response.to.have.status(200); });"] } }]
        },
        {
          "name": "Google Callback (manual)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/auth/callback/google?code=replace_me&state=replace_me",
              "host": ["{{apiBase}}"],
              "path": ["auth", "callback", "google"],
              "query": [
                { "key": "code", "value": "replace_me" },
                { "key": "state", "value": "replace_me" }
              ]
            },
            "description": "Run only with real OAuth callback values from browser flow."
          }
        }
      ]
    },
    {
      "name": "02 Auth Extended",
      "item": [
        {
          "name": "Profile GET",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{apiBase}}/auth/profile", "host": ["{{apiBase}}"], "path": ["auth", "profile"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Profile GET returns 200/401', function () { pm.expect([200,401]).to.include(pm.response.code); });"] } }]
        },
