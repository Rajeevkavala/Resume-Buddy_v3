        {
          "name": "OTP Send",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"destination\": \"{{email}}\",\n  \"channel\": \"email\",\n  \"purpose\": \"login\"\n}" },
            "url": { "raw": "{{apiBase}}/auth/otp/send", "host": ["{{apiBase}}"], "path": ["auth", "otp", "send"] }
          }
        },
        {
          "name": "OTP Verify",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"destination\": \"{{email}}\",\n  \"code\": \"{{otpCode}}\",\n  \"channel\": \"email\",\n  \"purpose\": \"login\"\n}" },
            "url": { "raw": "{{apiBase}}/auth/otp/verify", "host": ["{{apiBase}}"], "path": ["auth", "otp", "verify"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('OTP verify returns 200/400/429', function () { pm.expect([200,400,401,403,404,429]).to.include(pm.response.code); });", "if (pm.response.code === 200) { const j = pm.response.json(); if (j.accessToken) pm.environment.set('accessToken', j.accessToken); if (j.user && j.user.id) pm.environment.set('userId', j.user.id); if (j.resetToken) pm.environment.set('resetToken', j.resetToken); }"] } }]
        }
      ]
    },
    {
      "name": "03 Resumes",
      "item": [
        {
          "name": "List Resumes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/resumes?page=1&limit=10&status=all",
              "host": ["{{apiBase}}"],
              "path": ["resumes"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "all" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Resumes list returns 200/401', function () { pm.expect([200,401]).to.include(pm.response.code); });", "if (pm.response.code === 200) { const j = pm.response.json(); if (j.resumes && j.resumes.length && j.resumes[0].id) pm.environment.set('resumeId', j.resumes[0].id); }"] } }]
        },
        {
          "name": "Upload Resume (multipart)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "{{resumeFilePath}}" },
                { "key": "title", "value": "{{resumeTitle}}", "type": "text" }
              ]
            },
            "url": { "raw": "{{apiBase}}/resumes/upload", "host": ["{{apiBase}}"], "path": ["resumes", "upload"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Upload returns 200/400/401', function () { pm.expect([200,400,401,404]).to.include(pm.response.code); });", "if (pm.response.code === 200) { const j = pm.response.json(); if (j.resumeDataId) pm.environment.set('resumeId', j.resumeDataId); if (j.fileId) pm.environment.set('fileId', j.fileId); if (j.objectKey) pm.environment.set('objectKey', j.objectKey); }"] } }]
        },
        {
          "name": "Generate Upload URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/resumes/upload-url?filename={{presignedUploadFilename}}&contentType={{presignedUploadContentType}}",
              "host": ["{{apiBase}}"],
              "path": ["resumes", "upload-url"],
              "query": [
                { "key": "filename", "value": "{{presignedUploadFilename}}" },
                { "key": "contentType", "value": "{{presignedUploadContentType}}" }
              ]
            }
          }
        },
        {
          "name": "Get Resume by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{apiBase}}/resumes/{{resumeId}}", "host": ["{{apiBase}}"], "path": ["resumes", "{{resumeId}}"] }
          }
        },
        {
          "name": "Patch Resume",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{resumeTitle}} Updated\",\n  \"resumeText\": \"{{resumeText}}\",\n  \"jobDescription\": \"{{jobDescription}}\",\n  \"jobRole\": \"{{jobRole}}\"\n}"
            },
            "url": { "raw": "{{apiBase}}/resumes/{{resumeId}}", "host": ["{{apiBase}}"], "path": ["resumes", "{{resumeId}}"] }
          }
        },
        {
          "name": "Archive Resume",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"archived\": true\n}" },
            "url": { "raw": "{{apiBase}}/resumes/{{resumeId}}/archive", "host": ["{{apiBase}}"], "path": ["resumes", "{{resumeId}}", "archive"] }
          }
        },
