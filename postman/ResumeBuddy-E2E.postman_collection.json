            "url": { "raw": "{{apiBase}}/auth/verify-email", "host": ["{{apiBase}}"], "path": ["auth", "verify-email"] }
          }
        },
        {
          "name": "Change Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"newEmail\": \"{{newEmail}}\",\n  \"currentPassword\": \"{{password}}\"\n}" },
